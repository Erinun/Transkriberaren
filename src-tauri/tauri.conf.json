{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "MötesSkribent",
  "version": "0.4.1",
  "identifier": "se.motesskribent.app",
  "build": {
    "frontendDist": "../app/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../app"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../app"
    }
  },
  "app": {
    "windows": [
      {
        "title": "MötesSkribent",
        "width": 900,
        "height": 700,
        "resizable": true,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "MötesSkribent"
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["sidecar/**/*"],
    "windows": {
      "nsis": {
        "languages": ["Swedish"],
        "installMode": "currentUser"
      }
    },
    "publisher": "MötesSkribent",
    "shortDescription": "Lokal mötesanteckning med AI"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
