{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "MötesSkribent",
  "version": "0.5.7",
  "identifier": "se.motesskribent.app",
  "build": {
    "frontendDist": "../app/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../app"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../app"
    }
  },
  "app": {
    "windows": [
      {
        "title": "MötesSkribent",
        "width": 900,
        "height": 700,
        "resizable": true,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "MötesSkribent"
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost https://github.com https://api.github.com https://objects.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["sidecar/**/*"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "compression": "zlib"
      }
    },
    "publisher": "MötesSkribent",
    "shortDescription": "Lokal mötesanteckning med AI"
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/Erinun/Transkriberaren/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1M0M1RDMyNjA5NjU4MDAKUldRQVdKWmdNbDA4NWZyRzlpeTlRSWVrSnBueko2cWRrYjRzUmpxVHQ2cWFEeHp1RmRxNjZUcUoK"
    }
  }
}
